digraph ConflictGraph {
  graph [rankdir=LR, labelloc="t", label="Interference graph (conflicts)"];
  node [shape=box, style="rounded"];
"A0" [label="Rename(public.users.email)", color="blue"];
"B0" [label="Modify(public.users.email)", color="red"];
"A0" -> "B0" [label="public.users.email\ntype.text"];
}